{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Messaging": {
    "Broker": "RabbitMq",
    "ConnectionStringName": "lynkly-rabbitmq",
    "RabbitMq": {
      "PublishRetryCount": 3,
      "MinRetryDelay": "00:00:01",
      "MaxRetryDelay": "00:00:30",
      "IntervalDelta": "00:00:03"
    }
  },
  "AllowedHosts": "*"
}
